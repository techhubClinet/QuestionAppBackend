# Local: PORT=5001 | Vercel: PORT is set automatically — omit or ignore
PORT=5001
MONGODB_URI=mongodb+srv://your-user:your-password@cluster0.xxxxx.mongodb.net/mamekubal
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_IDS=your-ios-client-id.apps.googleusercontent.com,your-android-client-id.apps.googleusercontent.com
# Optional: comma-separated admin allowlist (only these emails can access admin routes)
# ADMIN_EMAILS=maosim1991@gmail.com,pnina.matsanov1@gmail.com,nihaarshad5@gmail.com
#
# --- Vercel ---
# Import this repo with Root Directory = backend (or deploy only the backend folder).
# In Vercel → Settings → Environment Variables, set MONGODB_URI, JWT_SECRET, JWT_EXPIRES_IN, GOOGLE_CLIENT_IDS (and optional ADMIN_*).
# MongoDB Atlas: Network Access → allow 0.0.0.0/0 (or Vercel) so serverless can connect.
# App URL will be https://<project>.vercel.app — point the mobile API_URL to that host.
